# Copy to .env and fill in your keys

GOOGLE_API_KEY=AIza...
GENIUS_ACCESS_TOKEN=        # optional — improves lyrics fallback (genius.com/api-clients)
LASTFM_API_KEY=             # optional — seeds ~10k songs from Last.fm instead of built-in list

# Path to a lyrics CSV (e.g. Kaggle Spotify dataset). Leave blank to use built-in song list.
DATASET_PATH=data/songs.csv
