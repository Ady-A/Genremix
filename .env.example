# Copy to .env and fill in your keys
GOOGLE_API_KEY=AIza...

# Optional: Last.fm API key — free at last.fm/api/account/create
# Enables seeding ~10k songs from Last.fm charts instead of built-in list
LASTFM_API_KEY=

# Dataset path (CSV with columns: id,title,artist,lyrics,year,genre)
DATASET_PATH=data/songs.csv

# Minimum lyric length to filter low-quality rows
MIN_LYRIC_LENGTH=200
